<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SteamDb.ViewModels"
        xmlns:views="using:SteamDb.Views"
        xmlns:wv="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.WebView"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
        x:Class="SteamDb.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/gamedate.ico"
        Title="SteamDb"
        Height="620"
        Width="780">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <!-- Uniform sizing for every provider icon (Svg- or Image-based). -->
        <Style Selector="Svg.icon">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
        </Style>
        <Style Selector="Image.icon">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
        </Style>

        <!-- Uniform sizing for every clickable icon button (info / ko-fi). -->
        <Style Selector="Button.icon-button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Uniform sizing for every text input field. -->
        <Style Selector="TextBox.field">
            <Setter Property="Width" Value="220" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <!-- Shared card frame ("fieldset" with an icon breaking its border). -->
        <Style Selector="Border.card">
            <Setter Property="Width" Value="240" />
            <Setter Property="BorderBrush" Value="#80808080" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="40,14,20,14" />
            <Setter Property="Margin" Value="24,0,0,0" />
        </Style>
        <!-- Buttons inside a card fill the card width. -->
        <Style Selector="Border.card Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.animated-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.animated-button:pointerover">
            <Style.Animations>
                <Animation Duration="0:0:1" Easing="SineEaseInOut" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="6" />
                    </KeyFrame>
                    <KeyFrame Cue="25%">
                        <Setter Property="RotateTransform.Angle" Value="-6" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="RotateTransform.Angle" Value="6" />
                    </KeyFrame>
                    <KeyFrame Cue="75%">
                        <Setter Property="RotateTransform.Angle" Value="-6" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="6" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Button.ko-fi-button:pointerover">
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.8" Easing="SineEaseInOut" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.2" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.2" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="28,18">

        <!-- Hidden (1x1, transparent): pre-warms the WebView2 runtime at startup, and a few
             seconds in also loads the GOG login page in the background so the real Connect GOG
             window opens from cache. The user never sees it. -->
        <wv:NativeWebView x:Name="PrewarmWebView"
                          Grid.Row="0" Width="1" Height="1" Opacity="0"
                          IsHitTestVisible="False"
                          HorizontalAlignment="Left" VerticalAlignment="Top"
                          Source="about:blank" />

        <!-- Progress bar (shown while fetching games) + Cancel -->
        <Grid Grid.Row="0" Height="16" Margin="0,0,0,14" ColumnDefinitions="*,Auto"
              IsVisible="{Binding IsBusy}">
            <Panel Grid.Column="0">
                <ProgressBar Height="16"
                             IsIndeterminate="{Binding ProgressIsIndeterminate}"
                             Minimum="0"
                             Maximum="{Binding ProgressMaximum}"
                             Value="{Binding ProgressValue}" />
                <TextBlock FontSize="9"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Text="{Binding ProgressStatus}" />
            </Panel>
            <Button Grid.Column="1" Content="Cancel" FontSize="9" Padding="8,0" Margin="8,0,0,0"
                    VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                    Command="{Binding CancelCommand}" />
        </Grid>

        <!-- Two columns: credential inputs (left) and action cards (right) -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,56,Auto" VerticalAlignment="Top">

            <!-- ===== Left: credential inputs ===== -->
            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="12">

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Svg Classes="icon" Path="/Assets/steam.svg" />
                    <TextBox Classes="field revealPasswordButton" VerticalAlignment="Center"
                             PlaceholderText="Steam API key" UseFloatingPlaceholder="True" PasswordChar="*"
                             Text="{Binding SteamApiKey, Mode=TwoWay}" />
                    <Button Classes="animated-button icon-button"
                            Command="{Binding OpenSteamApiKeyInfoCommand}">
                        <Viewbox>
                            <Image Source="{DynamicResource InfoIcon}" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Svg Classes="icon" Path="/Assets/steam.svg" />
                    <TextBox Classes="field revealPasswordButton" VerticalAlignment="Center"
                             PlaceholderText="Steam ID" UseFloatingPlaceholder="True" PasswordChar="*"
                             Text="{Binding SteamId, Mode=TwoWay}" />
                    <Button Classes="animated-button icon-button"
                            Command="{Binding OpenInfoLinkSteamIdCommand}">
                        <Viewbox>
                            <Image Source="{DynamicResource InfoIcon}" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Classes="icon" Source="{DynamicResource NotionIcon}" />
                    <TextBox Classes="field revealPasswordButton" VerticalAlignment="Center"
                             PlaceholderText="Notion API integration token" UseFloatingPlaceholder="True"
                             PasswordChar="*"
                             Text="{Binding NotionToken, Mode=TwoWay}" />
                    <Button Classes="animated-button icon-button"
                            Command="{Binding OpenInfoLinkNotionTokenCommand}">
                        <Viewbox>
                            <Image Source="{DynamicResource InfoIcon}" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Classes="icon" Source="{DynamicResource NotionIcon}" />
                    <TextBox Classes="field revealPasswordButton" VerticalAlignment="Center"
                             PlaceholderText="Database ID" UseFloatingPlaceholder="True" PasswordChar="*"
                             Text="{Binding DbId, Mode=TwoWay}" />
                    <Button Classes="animated-button icon-button"
                            Command="{Binding OpenInfoLinkNotionDbIdCommand}">
                        <Viewbox>
                            <Image Source="{DynamicResource InfoIcon}" />
                        </Viewbox>
                    </Button>
                </StackPanel>

                <!-- Store connect rows (icon + Connect / code / Connected) — see StoreConnectRow. -->
                <views:StoreConnectRow DataContext="{Binding Epic}" Icon="{DynamicResource EpicIcon}" />
                <views:StoreConnectRow DataContext="{Binding Gog}" Icon="{DynamicResource GogIcon}" />
                <views:StoreConnectRow DataContext="{Binding Xbox}" Icon="{DynamicResource XboxIcon}" />
            </StackPanel>

            <!-- ===== Right: action cards (uniform width, evenly spaced) =====
                 Each card is a framed "fieldset" whose left border is broken by its
                 icon (opaque window-coloured background hides the line behind it). -->
            <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="16">

                <Panel HorizontalAlignment="Center">
                    <Border Classes="card">
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <Button Content="Export to .csv" Command="{Binding ExportToCsvCommand}" />
                            <Button Content="Update .csv" Command="{Binding UpdateCsvCommand}" />
                        </StackPanel>
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="{Binding $parent[Window].Background}" Padding="4,6">
                        <Image Classes="icon" Source="{DynamicResource CsvIcon}" />
                    </Border>
                </Panel>

                <Panel HorizontalAlignment="Center">
                    <Border Classes="card">
                        <Button Content="Export to Notion" Command="{Binding ExportToNotionCommand}" />
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="{Binding $parent[Window].Background}" Padding="4,6">
                        <Image Classes="icon" Source="{DynamicResource NotionIcon}" />
                    </Border>
                </Panel>

                <Panel HorizontalAlignment="Center">
                    <Border Classes="card">
                        <StackPanel Orientation="Vertical" Spacing="8">
                            <Button Content="Save settings" Command="{Binding SaveSettingsCommand}" />
                            <Button Content="Import settings" Command="{Binding ImportSettingsCommand}" />
                        </StackPanel>
                    </Border>
                    <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                            Background="{Binding $parent[Window].Background}" Padding="4,6">
                        <Image Classes="icon" Source="{DynamicResource SettingsIcon}" />
                    </Border>
                </Panel>

                <!-- Google Sheets (+ info button overflowing to the right) -->
                <Grid HorizontalAlignment="Center">
                    <Panel HorizontalAlignment="Center">
                        <Border Classes="card">
                            <StackPanel Orientation="Vertical" Spacing="8">
                                <Button Content="Export to Google Sheets" Height="40"
                                        VerticalContentAlignment="Center"
                                        Command="{Binding ExportToGoogleSheetsCommand}" />
                                <TextBox FontSize="10" HorizontalAlignment="Stretch"
                                         PlaceholderText="Google Sheets Table Name"
                                         UseFloatingPlaceholder="True"
                                         Text="{Binding GoogleSheetsTableName, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                                Background="{Binding $parent[Window].Background}" Padding="4,6">
                            <Svg Classes="icon" Path="/Assets/google-sheets-2026.svg" />
                        </Border>
                    </Panel>
                    <Button Classes="animated-button icon-button"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,-50,0"
                            Command="{Binding OpenInfoGoogleSheetsCommand}">
                        <Viewbox>
                            <Image Source="{DynamicResource InfoIcon}" />
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- Donation: titled fieldset with a clickable Ko-fi icon (bottom) -->
                <Panel HorizontalAlignment="Center">
                    <Border Classes="card" Margin="24,9,0,0" Padding="20,16,20,12">
                        <Button Classes="ko-fi-button icon-button" HorizontalAlignment="Center"
                                Command="{Binding OpenLinkKofi}">
                            <Viewbox>
                                <Image Source="{SvgImage /Assets/ko-fi.svg}" />
                            </Viewbox>
                        </Button>
                    </Border>
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="24,0,0,0"
                            Background="{Binding $parent[Window].Background}" Padding="8,0">
                        <TextBlock Text="Donation" FontSize="14" FontWeight="SemiBold" />
                    </Border>
                </Panel>
            </StackPanel>
        </Grid>
    </Grid>

</Window>